{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipStash Next",
  "version": "2.1.9",
  "identifier": "com.clipstash.next",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "需求暂存站 v2.1.9  @linjianglu",
        "width": 370,
        "height": 720,
        "minWidth": 360,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DATA/ClipStash Next/images/*",
          "$DATA/ClipStash/images/*",
          "$HOME/ClipStash/images/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "upgradeCode": "57ee616f-5a3f-52d9-a58b-f7f2358b0d09"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
